{
  "name": "governed-second-brain",
  "version": "0.1.6",
  "description": "Local-first governed second brain — a Claude Code + Cowork plugin + installer. Turn your own files into cited (qmd://) memory with deterministic governance and a tamper-evident, hash-chained audit trail. Runs in-process; no daemon, no network for retrieval.",
  "keywords": ["mcp", "claude-code", "cowork", "memory", "knowledge", "governance", "qmd", "citations", "local-first", "second-brain"],
  "license": "Apache-2.0",
  "author": "Jeremy Longshore <jeremy@intentsolutions.io>",
  "homepage": "https://github.com/jeremylongshore/governed-second-brain-plugin",
  "repository": { "type": "git", "url": "git+https://github.com/jeremylongshore/governed-second-brain-plugin.git" },
  "type": "module",
  "files": [
    "bin",
    "plugin-runtime/governed-brain.cjs",
    ".claude-plugin",
    "skills",
    ".mcp.json",
    "README.md",
    "LICENSE",
    "CLAUDE.md"
  ],
  "bin": {
    "governed-second-brain": "bin/init.mjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@qmd-team-intent-kb/common": "link:../qmd-team-intent-kb/packages/common",
    "@qmd-team-intent-kb/store": "link:../qmd-team-intent-kb/packages/store",
    "@qmd-team-intent-kb/schema": "link:../qmd-team-intent-kb/packages/schema",
    "@qmd-team-intent-kb/policy-engine": "link:../qmd-team-intent-kb/packages/policy-engine",
    "@qmd-team-intent-kb/qmd-adapter": "link:../qmd-team-intent-kb/packages/qmd-adapter",
    "@qmd-team-intent-kb/claude-runtime": "link:../qmd-team-intent-kb/packages/claude-runtime",
    "@qmd-team-intent-kb/curator": "link:../qmd-team-intent-kb/apps/curator",
    "@qmd-team-intent-kb/git-exporter": "link:../qmd-team-intent-kb/apps/git-exporter",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.0"
  }
}
